{
  "name": "mk-parser",
  "version": "0.1.0",
  "description": "Incremental Markdown parser for AI streaming scenarios",
  "type": "module",
  "exports": {
    ".": {
      "import": "./mk_parser_wasm.js",
      "require": "./mk_parser_cjs.cjs"
    },
    "./types": "./types.ts",
    "./wasm-api": "./mk_wasm_api.js"
  },
  "files": [
    "mk_parser_wasm.js",
    "mk_parser_cjs.cjs",
    "types.ts",
    "mk_parser.js",
    "mk_parser.wasm"
  ],
  "scripts": {
    "build:wasm": "cd ../.. && bash build.sh wasm",
    "copy:wasm":  "cp ../../build/wasm/mk_parser.js . && cp ../../build/wasm/mk_parser.wasm ."
  },
  "keywords": ["markdown", "parser", "streaming", "wasm", "incremental"],
  "license": "MIT"
}
